// OMEGA INFINITY 1000 — Prisma Schema (Complete)
// Enterprise AI orchestration platform database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  name         String
  avatar       String?
  role         UserRole   @default(DEVELOPER)
  status       UserStatus @default(ACTIVE)
  lastLogin    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  orgMembers   OrgMember[]
  organizations Organization[] @relation("OrgOwner")
  projects     Project[]  @relation("ProjectOwner")
  agents       Agent[]
  workflows    Workflow[]
  notifications Notification[]
  auditLogs    AuditLog[]
}

enum UserRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

// ============ ORGANIZATIONS ============

model Organization {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  logo        String?
  status      OrgStatus  @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  ownerId     String
  owner       User       @relation("OrgOwner", fields: [ownerId], references: [id])

  members     OrgMember[]
  projects    Project[]
  agents      Agent[]
  deployments Deployment[]
}

model OrgMember {
  id       String  @id @default(cuid())
  orgId    String
  userId   String
  role     OrgRole @default(DEVELOPER)
  joinedAt DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum OrgRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

// ============ PROJECTS ============

model Project {
  id          String         @id @default(cuid())
  name        String
  description String
  status      ProjectStatus  @default(PLANNING)
  techStack   String[]
  progress    Int            @default(0)
  repoUrl     String?
  liveUrl     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  ownerId     String
  owner       User           @relation("ProjectOwner", fields: [ownerId], references: [id])
  orgId       String?
  org         Organization?  @relation(fields: [orgId], references: [id])

  workflows   Workflow[]
  deployments Deployment[]
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ============ AI AGENTS ============

model Agent {
  id          String     @id @default(cuid())
  name        String
  type        AgentType
  description String
  capabilities String[]
  isActive    Boolean    @default(true)
  config      Json?
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id])
  ownerId     String?
  owner       User?      @relation(fields: [ownerId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum AgentType {
  ARCHITECT
  CODEGEN
  DEVOPS
  QA
  SECURITY
  DOCS
  DATABASE
  FRONTEND
  API
  ORCHESTRATOR
}

// ============ WORKFLOWS ============

model Workflow {
  id          String          @id @default(cuid())
  name        String
  description String
  status      WorkflowStatus  @default(PENDING)
  tasks       Json
  dependencies Json
  result      Json?
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id])
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  createdAt   DateTime        @default(now())
  completedAt DateTime?
}

enum WorkflowStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ============ DEPLOYMENTS ============

model Deployment {
  id           String   @id @default(cuid())
  environment  String
  platform     String
  url          String?
  status       String   @default("PENDING")
  version      String
  logs         String?
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  deployedAt   DateTime @default(now())
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  message   String
  priority  String    @default("normal")
  data      Json?
  read      Boolean   @default(false)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

// ============ AUDIT LOGS ============

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  details   String
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())
}
