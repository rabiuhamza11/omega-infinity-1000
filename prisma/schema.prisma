// OMEGA INFINITY 1000 — Prisma Schema
// Enterprise AI orchestration platform database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  passwordHash         String
  name                 String?
  avatarUrl            String?
  role                 String         @default("DEVELOPER")
  emailVerified        Boolean        @default(false)
  emailVerifyToken     String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  memberships   Membership[]
  projects      Project[]
  agents        Agent[]
  deployments   Deployment[]
  refreshTokens RefreshToken[]
}

// ============ REFRESH TOKENS ============

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ============ ORGANIZATIONS ============

model Organization {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]
  projects    Project[]
  agents      Agent[]
  deployments Deployment[]
}

enum OrgRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
  MEMBER
}

enum MemberStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole      @default(DEVELOPER)
  status         MemberStatus @default(ACTIVE)
  joinedAt       DateTime     @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

// ============ PROJECTS ============

model Project {
  id             String         @id @default(cuid())
  name           String
  description    String
  prompt         String?
  status         String         @default("PLANNING")
  techStack      String[]
  progress       Int            @default(0)
  repoUrl        String?
  liveUrl        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  userId         String
  user           User           @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id])

  tasks         Task[]
  deployments   Deployment[]
  artifacts     Artifact[]
  conversations Conversation[]
}

// ============ AI AGENTS ============

model Agent {
  id           String   @id @default(cuid())
  name         String
  type         String
  description  String?
  capabilities String[]
  enabled      Boolean  @default(true)
  config       Json?
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  userId       String?
  user         User?         @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks Task[]
}

// ============ TASKS ============

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  input       Json?
  priority    Int      @default(5)
  status      String   @default("QUEUED")
  startedAt   DateTime?
  output      Json?
  result      String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ============ DEPLOYMENTS ============

model Deployment {
  id           String          @id @default(cuid())
  environment  String?
  platform     String
  url          String?
  status       String          @default("PENDING")
  version      String?
  logs         String?
  config       Json?
  triggeredBy  String?
  deploymentId String?
  orgId        String?
  org          Organization?   @relation(fields: [orgId], references: [id])
  projectId    String?
  project      Project?        @relation(fields: [projectId], references: [id])
  deployedAt   DateTime        @default(now())
  createdAt    DateTime        @default(now())
}

// ============ ARTIFACTS ============

model Artifact {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String
  filePath  String?
  language  String?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============ CONVERSATIONS ============

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
