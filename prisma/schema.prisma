// OMEGA INFINITY 1000 — Prisma Schema (Complete)
// Enterprise AI orchestration platform database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  passwordHash        String
  name                String
  avatarUrl           String?
  role                UserRole   @default(DEVELOPER)
  status              UserStatus @default(ACTIVE)
  emailVerified       Boolean    @default(false)
  emailVerifyToken    String?
  passwordResetToken  String?
  passwordResetExpires DateTime?
  lastLogin           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  organizations Organization[] @relation("OrgOwner")
  projects      Project[]
  agents        Agent[]
  workflows     Workflow[]
  notifications  Notification[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  memberships   Membership[]
}

enum UserRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

// ============ REFRESH TOKENS ============

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============ ORGANIZATIONS ============

model Organization {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  status      String     @default("ACTIVE")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  ownerId     String?
  owner       User?      @relation("OrgOwner", fields: [ownerId], references: [id])

  memberships Membership[]
  projects    Project[]
  agents      Agent[]
  deployments Deployment[]
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("DEVELOPER")
  status         String   @default("ACTIVE")
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

// ============ PROJECTS ============

model Project {
  id             String   @id @default(cuid())
  name           String
  description    String
  status         String   @default("PLANNING")
  prompt         String?
  techStack      String[]
  progress       Int      @default(0)
  repoUrl        String?
  liveUrl        String?
  userId         String
  organizationId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  organization  Organization?  @relation(fields: [organizationId], references: [id])

  workflows    Workflow[]
  deployments  Deployment[]
  tasks        Task[]
  artifacts    Artifact[]
  conversations Conversation[]
}

// ============ AI AGENTS ============

model Agent {
  id          String   @id @default(cuid())
  name        String
  type        AgentType
  description String
  capabilities String[]
  enabled     Boolean  @default(true)
  config      Json?
  orgId       String?
  organization Organization? @relation(fields: [orgId], references: [id])
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
}

enum AgentType {
  ARCHITECT
  CODEGEN
  DEVOPS
  QA
  SECURITY
  DOCS
  DATABASE
  FRONTEND
  API
  ORCHESTRATOR
}

// ============ TASKS ============

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  input       Json?
  output      Json?
  result      String?
  priority    Int      @default(5)
  status      String   @default("QUEUED")
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
}

// ============ ARTIFACTS ============

model Artifact {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String
  filePath  String?
  language  String?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============ CONVERSATIONS ============

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============ WORKFLOWS ============

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String
  status      String   @default("PENDING")
  tasks       Json
  dependencies Json
  result      Json?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

// ============ DEPLOYMENTS ============

model Deployment {
  id           String   @id @default(cuid())
  environment  String   @default("production")
  platform     String
  url          String?
  status       String   @default("PENDING")
  version      String   @default("1.0.0")
  config       Json?
  triggeredBy  String?
  deploymentId String?
  logs         String?
  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id])
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  createdAt    DateTime @default(now())
  deployedAt   DateTime @default(now())
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  message   String
  priority  String    @default("normal")
  data      Json?
  read      Boolean   @default(false)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

// ============ AUDIT LOGS ============

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  details   String
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())
}
