// OMEGA INFINITY 1000 — Prisma Schema (Complete)
// Enterprise AI orchestration platform database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  passwordHash        String
  name                String
  avatarUrl           String?
  role                UserRole   @default(DEVELOPER)
  status              UserStatus @default(ACTIVE)
  emailVerified       Boolean    @default(false)
  emailVerifyToken    String?    @unique
  passwordResetToken  String?
  passwordResetExpires DateTime?
  lastLogin           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  memberships   Membership[]
  organizations Organization[] @relation("OrgOwner")
  projects     Project[]
  agents       Agent[]
  workflows    Workflow[]
  refreshTokens RefreshToken[]
  notifications Notification[]
  auditLogs    AuditLog[]
}

enum UserRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

// ============ ORGANIZATIONS ============

model Organization {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  logo        String?
  status      OrgStatus  @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  ownerId     String?
  owner       User?      @relation("OrgOwner", fields: [ownerId], references: [id])

  memberships Membership[]
  projects    Project[]
  agents      Agent[]
  deployments Deployment[]
}

model Membership {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole    @default(MEMBER)
  status         MemberStatus @default(ACTIVE)
  joinedAt       DateTime   @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  DEVELOPER
  VIEWER
}

enum MemberStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

// ============ PROJECTS ============

model Project {
  id             String         @id @default(cuid())
  name           String
  description    String
  prompt         String?
  status         String  @default("PLANNING")
  techStack      String[]
  progress       Int            @default(0)
  repoUrl        String?
  liveUrl        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  userId          String
  user            User          @relation(fields: [userId], references: [id])
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])

  tasks        Task[]
  workflows    Workflow[]
  deployments  Deployment[]
  artifacts    Artifact[]
  conversations Conversation[]
}

// ============ AI AGENTS ============

model Agent {
  id          String     @id @default(cuid())
  name        String
  type        AgentType
  description String?
  capabilities String[]
  enabled     Boolean    @default(true)
  config      Json?
  organizationId String?
  org         Organization? @relation(fields: [organizationId], references: [id])
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks Task[]
}

enum AgentType {
  ARCHITECT
  CODEGEN
  DEVOPS
  QA
  SECURITY
  DOCS
  DATABASE
  FRONTEND
  API
  ORCHESTRATOR
}

// ============ TASKS ============

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("QUEUED")
  priority    Int      @default(5)
  input       Json?
  output      Json?
  result      String?
  projectId   String
  agentId     String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent       Agent?   @relation(fields: [agentId], references: [id])
}

// ============ ARTIFACTS ============

model Artifact {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String
  filePath  String?
  language  String?
  projectId String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============ CONVERSATIONS ============

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  message   String
  role      String   @default("user")
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============ REFRESH TOKENS ============

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ WORKFLOWS ============

model Workflow {
  id          String          @id @default(cuid())
  name        String
  description String
  status      WorkflowStatus  @default(PENDING)
  tasks       Json
  dependencies Json
  result      Json?
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id])
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  createdAt   DateTime        @default(now())
  completedAt DateTime?
}

enum WorkflowStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ============ DEPLOYMENTS ============

model Deployment {
  id           String   @id @default(cuid())
  environment  String?
  platform     String
  url          String?
  status       String   @default("PENDING")
  version      String?
  config       Json?
  deploymentId String?
  triggeredBy  String?
  logs         String?
  organizationId String?
  org          Organization? @relation(fields: [organizationId], references: [id])
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  createdAt    DateTime @default(now())
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  message   String
  priority  String    @default("normal")
  data      Json?
  read      Boolean   @default(false)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

// ============ AUDIT LOGS ============

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  details   String
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())
}
