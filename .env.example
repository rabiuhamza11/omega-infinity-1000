# OMEGA INFINITY 1000 — Environment Configuration

# ============ DATABASE ============
DATABASE_URL="postgresql://postgres:password@localhost:5432/omega_infinity?schema=public"
REDIS_URL="redis://localhost:6379"

# ============ AUTH ============
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_CLIENT_SECRET=""
OAUTH_GITHUB_CLIENT_ID=""
OAUTH_GITHUB_CLIENT_SECRET=""

# ============ AI / AGENTS ============
OPENAI_API_KEY=""
AI_MODEL="gpt-4"
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.3

# ============ DEPLOYMENT INTEGRATIONS ============
# GitHub
GITHUB_TOKEN=""
GITHUB_ORG=""
# Vercel
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
# Render
RENDER_API_KEY=""

# ============ WORKFLOW ENGINE ============
WORKFLOW_MAX_PARALLEL=5
WORKFLOW_TIMEOUT_MS=300000
WORKFLOW_RETRY_COUNT=3

# ============ SERVER ============
PORT=4000
CORS_ORIGIN="http://localhost:3000"
LOG_LEVEL="debug"

# ============ SECURITY ============
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12

# ============ FILE STORAGE ============
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
